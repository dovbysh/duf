version: '3.8'

services:
  manticore:
    image: manticoresearch/manticore:latest
    container_name: manticore_indexer
    restart: always
    environment:
      - EXTRA=1
    ports:
      - "9306:9306" # MySQL интерфейс
      - "9308:9308" # HTTP интерфейс
    volumes:
      - manticore_data:/var/lib/manticore
    ulimits:
      nproc: 65535
      nofile:
        soft: 65535
        hard: 65535

volumes:
  manticore_data:
    driver: local
