services:
  postgres:
    image: postgres:18-alpine
    container_name: duf_postgres
    restart: always
    environment:
      POSTGRES_DB: duf
      POSTGRES_USER: duf
      POSTGRES_PASSWORD: duf
    ports:
      - "55432:5432"
    volumes:
      - postgres18_data:/var/lib/postgresql

volumes:
  postgres18_data:
    driver: local
