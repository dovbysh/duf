storage:
  scan_paths:
    - "/path/to/your/files"
  exclude_patterns:
    - "**/node_modules/**"
    - "**/.git/**"
    - "*.tmp"

database:
  dsn: "postgres://duf:duf@127.0.0.1:55432/duf?sslmode=disable"
  table_name: "duf.files"
  batch_size: 1000

performance:
  hash_workers: 2 # Ограничение для HDD
  buffer_size: 1MB # Размер буфера при чтении файла для хеша
